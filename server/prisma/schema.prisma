generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  TENANT
  OWNER
  ADMIN
}

enum PropertyType {
  APARTMENT
  ROOM
  STUDIO
  SHARED
}

enum ListingStatus {
  ACTIVE
  PAUSED
  RENTED
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  DECLINED
  CANCELLED
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  passwordHash String
  role         Role           @default(TENANT)
  university   String
  phone        String?
  avatarUrl    String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  ownedListings Listing[]     @relation("ListingOwner")
  favorites    Favorite[]
  tenantConversations Conversation[] @relation("TenantConversations")
  ownerConversations  Conversation[] @relation("OwnerConversations")
  sentMessages Message[]
  tenantAppointments Appointment[] @relation("TenantAppointments")
  ownerAppointments Appointment[] @relation("OwnerAppointments")
}

model Listing {
  id            String         @id @default(cuid())
  ownerId       String
  title         String
  description   String
  address       String
  city          String
  state         String
  zip           String
  latitude      Float
  longitude     Float
  rent          Int
  deposit       Int
  bedrooms      Float
  bathrooms     Float
  areaSqft      Int
  propertyType  PropertyType
  leaseTerm     String
  availableFrom DateTime
  amenities     String[]
  status        ListingStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  owner         User           @relation("ListingOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  images        ListingImage[]
  favorites     Favorite[]
  conversations Conversation[]
  appointments  Appointment[]
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  filename  String
  createdAt DateTime @default(now())
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Conversation {
  id         String   @id @default(cuid())
  listingId  String
  tenantId   String
  ownerId    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenant     User     @relation("TenantConversations", fields: [tenantId], references: [id], onDelete: Cascade)
  owner      User     @relation("OwnerConversations", fields: [ownerId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([listingId, tenantId, ownerId])
}

model Message {
  id            String       @id @default(cuid())
  conversationId String
  senderId      String
  body          String
  readAt        DateTime?
  createdAt     DateTime     @default(now())
  conversation  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender        User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

model Appointment {
  id          String            @id @default(cuid())
  listingId   String
  tenantId    String
  ownerId     String
  scheduledAt DateTime
  note        String?
  status      AppointmentStatus @default(REQUESTED)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  listing     Listing           @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenant      User              @relation("TenantAppointments", fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User              @relation("OwnerAppointments", fields: [ownerId], references: [id], onDelete: Cascade)
}

